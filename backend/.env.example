# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host:5432/hellocoolie?sslmode=require

# JWT
JWT_SECRET=hellocoolie_jwt_secret_change_in_production
JWT_EXPIRES_IN=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# MSG91 OTP
MSG91_AUTH_KEY=your_msg91_key
MSG91_SENDER_ID=HELLOC
MSG91_TEMPLATE_ID=your_template_id

# Firebase (push notifications)
FIREBASE_PROJECT_ID=hellocoolie
FIREBASE_PRIVATE_KEY=your_firebase_key
FIREBASE_CLIENT_EMAIL=your_firebase_email

# Platform settings
PLATFORM_FEE_NORMAL=15
PLATFORM_FEE_FESTIVAL=25
PLATFORM_FEE_CITY_X=20
BASE_FARE=80
PORTER_NOTIFY_SECONDS=30
MAX_BAGS_SINGLE_PORTER=4
CANCEL_WINDOW_MINUTES=15
FRAUD_CANCEL_THRESHOLD=3
MIN_WITHDRAWAL_AMOUNT=100

# Admin credentials (seed)
ADMIN_EMAIL=admin@hellocoolie.in
ADMIN_PASSWORD=Admin@123
ADMIN_PAN=ABCPA1234A
